# Get these from https://dashboard.stripe.com/apikeys (test mode to start)
STRIPE_SECRET_KEY=sk_test_...

# Safe to expose to the browser (unlike the secret key above). Required —
# the frontend's embedded payment modal (Stripe Payment Element) uses this
# to initialize Stripe.js via the /config endpoint.
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Get this from https://dashboard.stripe.com/webhooks after creating an
# endpoint (or from `stripe listen` when testing locally with the CLI)
STRIPE_WEBHOOK_SECRET=whsec_...

# Used to build success_url / cancel_url for Checkout redirects
APP_URL=http://localhost:4242

# Choose "sqlite" (zero setup, good for local dev) or "postgres" (production)
DB_DRIVER=sqlite

# Only used when DB_DRIVER=sqlite. Path to the local database file.
SQLITE_PATH=donations.db

# Only used when DB_DRIVER=postgres. Get this from your provider
# (Railway, Render, Supabase, RDS, etc.)
DATABASE_URL=postgres://user:password@host:5432/dbname
